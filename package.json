{
  "name": "mutt-logbook-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:android": "expo run:android",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.ts",
      "<rootDir>/src/__tests__/**/*.test.tsx"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"]
  },
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.1.1",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.5",
    "@react-navigation/native": "^7.1.5",
    "@react-navigation/native-stack": "^7.3.6",
    "axios": "^0.27.2",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-location": "~18.0.10",
    "expo-secure-store": "~14.0.1",
    "expo-sqlite": "~15.1.2",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-crypto": "^2.2.1",
    "react-native-gifted-charts": "^1.4.74",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "stream-browserify": "^3.0.0",
    "url": "^0.11.4",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "jest": "^30.2.0",
    "jest-expo": "^55.0.9",
    "typescript": "~5.3.3"
  },
  "private": true
}
